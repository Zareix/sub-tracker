{
	"name": "sub-tracker",
	"version": "1.22.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "bun run --bun next build",
		"build:analyze": "ANALYZE=true bun run --bun next build",
		"db:generate": "bunx drizzle-kit generate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"dev": "bun run --bun next dev --turbo",
		"start": "next start",
		"lint": "tsc --noEmit",
		"check": "biome check --write .",
		"email:dev": "email dev -d src/server/email/templates -p 3001",
		"auth:generate": "bunx --bun @better-auth/cli generate --config src/server/auth.ts",
		"test": "bun run --parallel test:int test:e2e",
		"test:int": "bun test --preload ./src/tests/integrations/_setup.ts ./src/tests/integrations",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:report": "playwright show-report"
	},
	"packageManager": "bun@1.3.8",
	"dependencies": {
		"@base-ui/react": "^1.3.0",
		"@better-auth/api-key": "^1.5.6",
		"@better-auth/passkey": "^1.5.6",
		"@estruyf/github-actions-reporter": "^1.11.0",
		"@hookform/resolvers": "^5.2.2",
		"@next/bundle-analyzer": "^16.2.1",
		"@react-email/components": "1.0.10",
		"@react-email/tailwind": "2.0.6",
		"@t3-oss/env-nextjs": "^0.13.11",
		"@tanstack/react-query": "^5.95.2",
		"@tanstack/react-query-devtools": "^5.95.2",
		"@trpc/client": "^11.16.0",
		"@trpc/next": "^11.16.0",
		"@trpc/react-query": "^11.16.0",
		"@trpc/server": "^11.16.0",
		"@types/nodemailer": "^7.0.11",
		"better-auth": "^1.5.6",
		"bun-fetch-mock": "^1.0.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"date-fns": "^4.1.0",
		"drizzle-orm": "^0.45.2",
		"lucide-react": "^1.7.0",
		"next": "^16.2.1",
		"next-intl": "^4.8.3",
		"next-themes": "^0.4.6",
		"node-cron": "^4.2.1",
		"nodemailer": "^8.0.4",
		"nuqs": "^2.8.9",
		"react": "^19.2.4",
		"react-day-picker": "^9.14.0",
		"react-dom": "^19.2.4",
		"react-hook-form": "^7.72.0",
		"react-scan": "^0.5.3",
		"recharts": "^2.15.4",
		"sharp": "^0.34.5",
		"sonner": "^2.0.7",
		"superjson": "^2.2.6",
		"tailwind-merge": "^3.5.0",
		"vaul": "^1.1.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@playwright/test": "^1.58.2",
		"@react-email/preview-server": "5.2.10",
		"@tailwindcss/postcss": "^4.2.2",
		"@total-typescript/ts-reset": "^0.6.1",
		"@types/bun": "^1.3.11",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"babel-plugin-react-compiler": "^1.0.0",
		"drizzle-kit": "^0.31.10",
		"postcss": "^8.5.8",
		"react-email": "6.0.0",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2"
	},
	"ct3aMetadata": {
		"initVersion": "7.38.1"
	}
}
